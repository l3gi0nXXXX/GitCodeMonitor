{
  "schema": "metis.servicePlugin.v1",
  "pluginId": "gitcode-monitor",
  "displayName": "GitCode Monitor",
  "kind": "service",
  "protocolVersion": "1.0",
  "entry": {
    "command": "./target/release/bin/gitcodemonitor",
    "args": ["plugin-stdio"]
  },
  "capabilityDeclarations": [
    {"capabilityId": "gitcode.monitor.status", "kind": "controlAction", "direction": "metis-to-gcm"},
    {"capabilityId": "gitcode.monitor.scan_once", "kind": "controlAction", "direction": "metis-to-gcm"},
    {"capabilityId": "gitcode.monitor.job_status", "kind": "controlAction", "direction": "metis-to-gcm"},
    {"capabilityId": "gitcode.monitor.cancel_job", "kind": "controlAction", "direction": "metis-to-gcm"},
    {"capabilityId": "gitcode.webhook.status", "kind": "controlAction", "direction": "metis-to-gcm"},
    {"capabilityId": "gitcode.webhook.dead_letter_list", "kind": "controlAction", "direction": "metis-to-gcm"},
    {"capabilityId": "gitcode.webhook.dead_letter_inspect", "kind": "controlAction", "direction": "metis-to-gcm"},
    {"capabilityId": "gitcode.webhook.replay", "kind": "controlAction", "direction": "metis-to-gcm"},
    {"capabilityId": "gitcode.webhook.cancel", "kind": "controlAction", "direction": "metis-to-gcm"},
    {"capabilityId": "gitcode.webhook.reconcile_hooks", "kind": "controlAction", "direction": "metis-to-gcm"},
    {"capabilityId": "gitcode.webhook.reconcile_events", "kind": "controlAction", "direction": "metis-to-gcm"},
    {"capabilityId": "gitcode.monitor.scan_progress", "kind": "event", "direction": "gcm-to-metis"},
    {"capabilityId": "gitcode.monitor.scan_completed", "kind": "event", "direction": "gcm-to-metis"},
    {"capabilityId": "gitcode.monitor.scan_failed", "kind": "event", "direction": "gcm-to-metis"},
    {"capabilityId": "gitcode.monitor.scan_cancelled", "kind": "event", "direction": "gcm-to-metis"},
    {"capabilityId": "gitcode.monitor.orphan_detected", "kind": "event", "direction": "gcm-to-metis"},
    {"capabilityId": "gitcode.event.accepted", "kind": "event", "direction": "gcm-to-metis"},
    {"capabilityId": "gitcode.event.ignored", "kind": "event", "direction": "gcm-to-metis"},
    {"capabilityId": "gitcode.writeback.apply_result", "kind": "controlAction", "direction": "metis-to-gcm"},
    {"capabilityId": "gitcode.writeback.audit", "kind": "event", "direction": "gcm-to-metis"}
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "configPath": {"type": "string", "title": "GCM config path"}
    },
    "required": ["configPath"]
  }
}
