{
  "schema": "metis.servicePlugin.v1",
  "pluginId": "gitcode-monitor",
  "displayName": "GitCode Monitor",
  "kind": "service",
  "protocolVersion": "1.0",
  "entry": {
    "command": "cjpm",
    "args": ["run", "--skip-build", "--name", "gitcodemonitor", "--run-args", "plugin-stdio"]
  },
  "capabilityDeclarations": [
    {"capabilityId": "gitcode.monitor.status", "kind": "controlAction", "direction": "metis-to-gcm"},
    {"capabilityId": "gitcode.monitor.scan_once", "kind": "controlAction", "direction": "metis-to-gcm"},
    {"capabilityId": "gitcode.event.accepted", "kind": "event", "direction": "gcm-to-metis"},
    {"capabilityId": "gitcode.event.ignored", "kind": "event", "direction": "gcm-to-metis"},
    {"capabilityId": "gitcode.agent.draft_request", "kind": "agentRequest", "direction": "gcm-to-metis", "requiredHostApis": ["host.agent.invoke"]},
    {"capabilityId": "gitcode.notification.generated_reply", "kind": "notificationTopic", "direction": "metis-internal-delivery", "requiredHostApis": ["host.notification.publish"]},
    {"capabilityId": "gitcode.writeback.apply_result", "kind": "controlAction", "direction": "metis-to-gcm"},
    {"capabilityId": "gitcode.writeback.audit", "kind": "event", "direction": "gcm-to-metis"}
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "configPath": {"type": "string", "title": "GCM config path"}
    },
    "required": ["configPath"]
  }
}
